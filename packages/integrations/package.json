{
  "name": "@coherent.js/integrations",
  "version": "1.0.0-rc.6",
  "description": "Framework integration adapters for Coherent.js: Express, Fastify, Koa, Next.js, Astro, Remix, SvelteKit.",
  "type": "module",
  "exports": {
    "./express": {
      "types": "./types/express/index.d.ts",
      "default": "./src/express/index.js"
    },
    "./fastify": {
      "types": "./types/fastify/index.d.ts",
      "default": "./src/fastify/index.js"
    },
    "./koa": {
      "default": "./src/koa/index.js"
    },
    "./nextjs": {
      "types": "./types/nextjs/index.d.ts",
      "default": "./src/nextjs/index.js"
    },
    "./astro": {
      "default": "./src/astro/index.js"
    },
    "./remix": {
      "default": "./src/remix/index.js"
    },
    "./sveltekit": {
      "default": "./src/sveltekit/index.js"
    }
  },
  "files": [
    "src/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomdrouv1/coherent.js.git"
  },
  "homepage": "https://github.com/Tomdrouv1/coherent.js",
  "bugs": {
    "url": "https://github.com/Tomdrouv1/coherent.js/issues"
  },
  "dependencies": {
    "fastify-plugin": "^6.0.0"
  },
  "peerDependencies": {
    "@coherent.js/core": "workspace:*",
    "@remix-run/server-runtime": ">=2.0.0",
    "@sveltejs/kit": ">=2.0.0",
    "astro": ">=4.0.0",
    "express": ">=4.18.0 < 6.0.0",
    "fastify": ">=4.0.0 < 6.0.0",
    "koa": ">=2.13.0 < 4.0.0",
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@remix-run/server-runtime": {
      "optional": true
    },
    "@sveltejs/kit": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
