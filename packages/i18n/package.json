{
  "name": "@coherent.js/i18n",
  "version": "1.0.0-rc.6",
  "description": "Internationalization support for Coherent.js applications",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./translator": "./dist/translator.js",
    "./formatters": "./dist/formatters.js",
    "./locale": "./dist/locale.js"
  },
  "keywords": [
    "coherent",
    "i18n",
    "internationalization",
    "localization",
    "translation"
  ],
  "author": "Coherent.js Team",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@coherent.js/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomdrouv1/coherent.js.git"
  },
  "homepage": "https://github.com/Tomdrouv1/coherent.js",
  "bugs": {
    "url": "https://github.com/Tomdrouv1/coherent.js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "types": "./types/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "types/"
  ],
  "sideEffects": false
}
