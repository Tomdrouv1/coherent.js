{
  "name": "@coherent.js/tooling",
  "version": "1.0.0-rc.1",
  "description": "Coherent.js dev-time tooling: testing utilities (Vitest matchers, render harness) and Language Server Protocol implementation.",
  "type": "module",
  "main": "./dist/testing/index.js",
  "types": "./types/testing/index.d.ts",
  "exports": {
    "./testing": {
      "types": "./types/testing/index.d.ts",
      "development": "./src/testing/index.js",
      "import": "./dist/testing/index.js"
    },
    "./testing/renderer": {
      "types": "./types/testing/index.d.ts",
      "development": "./src/testing/test-renderer.js",
      "import": "./dist/testing/test-renderer.js"
    },
    "./testing/utils": {
      "types": "./types/testing/index.d.ts",
      "development": "./src/testing/test-utils.js",
      "import": "./dist/testing/test-utils.js"
    },
    "./testing/matchers": {
      "types": "./types/testing/index.d.ts",
      "development": "./src/testing/matchers.js",
      "import": "./dist/testing/matchers.js"
    },
    "./lsp": {
      "types": "./dist/lsp/server.d.ts",
      "import": "./dist/lsp/server.js"
    }
  },
  "bin": {
    "coherent-language-server": "./dist/lsp/server.js"
  },
  "files": [
    "dist/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist",
    "dev": "tsc -w",
    "start": "node dist/lsp/server.js --stdio",
    "extract-attributes": "tsx scripts/extract-attributes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "coherent",
    "testing",
    "test-utils",
    "component-testing",
    "language-server",
    "lsp",
    "vscode",
    "ide",
    "autocomplete",
    "validation"
  ],
  "author": "Coherent.js Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomdrouv1/coherent.js.git",
    "directory": "packages/tooling"
  },
  "homepage": "https://github.com/Tomdrouv1/coherent.js",
  "bugs": {
    "url": "https://github.com/Tomdrouv1/coherent.js/issues"
  },
  "peerDependencies": {
    "@coherent.js/core": "workspace:*"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false
}
