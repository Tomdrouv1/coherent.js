{
  "name": "@coherent.js/database",
  "version": "1.0.0-rc.6",
  "description": "Database utilities and adapters for Coherent.js",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./model": {
      "default": "./dist/model.js"
    },
    "./migration": {
      "default": "./dist/migration.js"
    },
    "./connection": {
      "default": "./dist/connection-manager.js"
    },
    "./middleware": {
      "default": "./dist/middleware.js"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:vitest": "vitest run",
    "test:node": "node --test test/*.test.js"
  },
  "files": [
    "types/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomdrouv1/coherent.js.git"
  },
  "homepage": "https://github.com/Tomdrouv1/coherent.js",
  "bugs": {
    "url": "https://github.com/Tomdrouv1/coherent.js/issues"
  },
  "peerDependencies": {
    "sqlite3": ">=5.0.0",
    "@coherent.js/core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "sqlite3": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false
}
