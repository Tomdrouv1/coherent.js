{
  "name": "@coherent.js/monorepo",
  "version": "1.0.0-beta.8",
  "private": true,
  "description": "A lightweight, high-performance server-side rendering framework using pure JavaScript objects. Features include streaming renderer, performance monitoring, component composition, memoization, and integrations with Express.js, Fastify, and Next.js.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run --no-cache",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:packages": "pnpm -r run test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --no-cache",
    "coverage:report": "node scripts/generate-coverage-report.js",
    "build": "pnpm run build:packages",
    "build:packages": "pnpm -r --stream run build",
    "build:types": "tsc --build",
    "publish:beta": "pnpm publish -r --access public --tag beta --no-git-checks",
    "publish:latest": "pnpm publish -r --access public --no-git-checks",
    "release": "pnpm changeset version && pnpm publish -r --access public --no-git-checks",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "dev": "pnpm run website:dev",
    "clean": "pnpm -r run clean && rm -rf dist/",
    "demo": "node examples/master-showcase.js",
    "example:basic": "node examples/basic-usage.js",
    "example:components": "node examples/components-test.js",
    "example:performance": "node examples/performance-test.js",
    "example:advanced": "node examples/advanced-features.js",
    "example:streaming": "node examples/streaming-renderer.js",
    "example:security": "node examples/security-test.js",
    "example:hydration": "node examples/hydration-test.js",
    "example:memoization": "node examples/memoization-test.js",
    "example:composition": "node examples/component-composition.js",
    "lint": "eslint packages/*/src/**/*.js packages/*/test/**/*.js examples/**/*.js scripts/**/*.js scripts/**/*.mjs --max-warnings=0",
    "lint:fix": "eslint packages/*/src/**/*.js packages/*/test/**/*.js examples/**/*.js scripts/**/*.js scripts/**/*.mjs --fix",
    "format": "prettier --write packages/ tests/ examples/",
    "format:check": "prettier --check packages/ tests/ examples/",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --strict",
    "typecheck:packages": "pnpm -r run typecheck",
    "website:build": "node website/build.js",
    "website:dev": "node --watch website/src/index.js",
    "website:start": "node website/src/index.js",
    "version": "pnpm changeset version",
    "prepare": "husky",
    "prepack": "pnpm run build",
    "security:audit": "pnpm audit --audit-level high",
    "security:update": "pnpm update --latest",
    "security:check": "pnpm outdated",
    "perf:analyze": "node scripts/analyze-bundle.mjs",
    "perf:build": "NODE_ENV=production pnpm build",
    "perf:benchmark": "node benchmarks/benchmark.js",
    "perf:gate": "node benchmarks/perf-gate.js",
    "test:node": "pnpm -r run test:node"
  },
  "keywords": [
    "ssr",
    "server-side-rendering",
    "html",
    "javascript",
    "objects",
    "express",
    "fastify",
    "nextjs",
    "framework",
    "performance",
    "streaming",
    "components",
    "hydration"
  ],
  "author": "Thomas Drouvin <thomas.drouvin@collektivs.com> (https://coherentjs.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tomdrouv1/coherent.js.git"
  },
  "bugs": {
    "url": "https://github.com/Tomdrouv1/coherent.js/issues"
  },
  "homepage": "https://github.com/Tomdrouv1/coherent.js#readme",
  "peerDependencies": {
    "express": ">=4.18.0 < 6.0.0",
    "fastify": ">=4.0.0 < 6.0.0",
    "koa": ">=2.13.0 < 4.0.0",
    "mongodb": ">=5.0.0 < 7.0.0",
    "mysql2": ">=3.0.0 < 4.0.0",
    "pg": ">=8.8.0 < 9.0.0",
    "sqlite3": ">=5.1.0 < 6.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@codecov/vite-plugin": "1.9.1",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.2",
    "chokidar": "5.0.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "marked": "17.0.6",
    "prettier": "3.8.1",
    "shiki": "4.0.2",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "ws": "8.20.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/react"
      ]
    },
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar",
      "sharp",
      "sqlite3"
    ]
  }
}
